generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  PARENT
  ADMIN
  HR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String
  name              String
  role              Role
  institutionId     String?
  sectionId         String?
  rollNumber        String?            @unique
  parentEmail       String?
  mobileNumber      String?
  avatar            String?
  isActive          Boolean            @default(true)
  isEmailVerified   Boolean            @default(false)
  isMobileVerified  Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  institution       Institution?       @relation(fields: [institutionId], references: [id])
  section           Section?           @relation(fields: [sectionId], references: [id])
  attendanceRecords AttendanceRecord[]
  qrSessions        QRSession[]
}

model Institution {
  id                String             @id @default(cuid())
  name              String
  code              String             @unique
  address           String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  users             User[]
  sections          Section[]
  attendanceRecords AttendanceRecord[]
  qrSessions        QRSession[]
}

model Section {
  id            String      @id @default(cuid())
  name          String
  institutionId String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id])
  users         User[]
  qrSessions    QRSession[]
}

model AttendanceRecord {
  id                String           @id @default(cuid())
  userId            String
  institutionId     String
  qrSessionId       String
  status            AttendanceStatus
  deviceFingerprint String
  ipAddress         String?
  markedAt          DateTime         @default(now())
  createdAt         DateTime         @default(now())
  
  user              User             @relation(fields: [userId], references: [id])
  institution       Institution      @relation(fields: [institutionId], references: [id])
  qrSession         QRSession        @relation(fields: [qrSessionId], references: [id])

  @@index([userId, markedAt])
  @@index([institutionId, markedAt])
  @@index([qrSessionId])
}

model QRSession {
  id                String             @id @default(cuid())
  institutionId     String
  sectionId         String?
  createdById       String
  expiresAt         DateTime
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  
  institution       Institution        @relation(fields: [institutionId], references: [id])
  section           Section?           @relation(fields: [sectionId], references: [id])
  createdBy         User               @relation(fields: [createdById], references: [id])
  attendanceRecords AttendanceRecord[]

  @@index([institutionId, isActive])
  @@index([sectionId])
}

model OtpRecord {
  id          String   @id @default(cuid())
  identifier  String   // Email or Mobile number
  code        String   // OTP code
  type        String   // 'EMAIL' or 'MOBILE'
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([identifier])
}
